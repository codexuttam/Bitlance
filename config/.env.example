# Email Configuration (SendGrid/Mailgun/SES)
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=your_sendgrid_api_key_here

# Outreach Settings
FROM_NAME=John from Bitlance
FROM_EMAIL=outreach@yourdomain.com
REPLY_TO=replies@yourdomain.com

# Auto-Reply Listener Configuration
IMAP_HOST=imap.gmail.com
REPLY_TO_USER=replies@yourdomain.com
REPLY_TO_PASS=your_app_password_here

# Email Finder API (Hunter.io)
HUNTER_API_KEY=your_hunter_api_key_here

# AI API Key (Google Gemini or OpenAI)
AI_API_KEY=your_api_key_here

# Scraping Settings
MAX_CEOS=100
